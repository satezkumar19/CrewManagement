# L1 SignalFabric — environment (all optional; dev-safe defaults baked in)

# Tenant stamped on every SignalEvent
L1_TENANT_ID=maritime-acme

# --- Slack ---
# Set the app signing secret to enforce HMAC verification. When empty AND
# SLACK_DEV_ALLOW_UNVERIFIED=1, unsigned requests are accepted (local/demo).
SLACK_SIGNING_SECRET=
SLACK_DEV_ALLOW_UNVERIFIED=1
SLACK_REPLAY_WINDOW_SEC=300

# --- ERP ---
# Path to persist the outbox watermark across restarts ("" => in-memory only)
ERP_WATERMARK_PATH=

# --- server ---
HOST=0.0.0.0
PORT=8001
